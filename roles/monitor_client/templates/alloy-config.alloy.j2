/* 
  Host: {{ inventory_hostname }}
  Generated by Ansible - Do not edit manually
*/

// Metrics Collection (node_exporter replacement)
prometheus.exporter.unix "linux" {
  include_exporter_metrics = true
}

prometheus.scrape "linux" {
  targets = prometheus.exporter.unix.linux.targets
  forward_to = [prometheus.remote_write.monitor.receiver]
}

// Logs Collection (promtail replacement)
loki.source.journal "system" {
  forward_to = [loki.write.monitor.receiver]
  labels = {
    job = "systemd-journal",
    host = "{{ inventory_hostname }}",
  }
}

// We can also add file scraping if needed to match promtail exactly, but usually journal covers most system needs.
// If legacy promtail successfully scraped /var/log/*, we might need loki.source.file. 
// Assuming journal is sufficient for "system logs" requirement for now as per plan.

// Exporters

// Metrics -> Prometheus Remote Write
prometheus.remote_write "monitor" {
  endpoint {
    url = "{{ prometheus_write_uri }}"
  }
}

// Logs -> Loki Push
loki.write "monitor" {
  endpoint {
    url = "{{ loki_write_uri }}"
  }
}
