global:
  scrape_interval: 30s
  scrape_timeout: 10s
  external_labels:
    cluster: 'monitor_server'
    environment: 'production'

rule_files:
  - alert.yml

scrape_configs:
  - job_name: local_prometheus
    metrics_path: /metrics
    static_configs:
      - targets:
          - 'localhost:9090'

  - job_name: node  # node_exporter
    metrics_path: /metrics
    static_configs:
      - targets:
{% for monitored_host in monitored_hosts %}
          - '{{ monitored_host }}:9100'
{% endfor %}

  - job_name: alloy-internal
    metrics_path: /metrics
    static_configs:
      - targets:
        {% for monitored_host in monitored_hosts %}
          - '{{ monitored_host }}:12345'
        {% endfor %}

  - job_name: traefik
    metrics_path: /metrics
    static_configs:
      - targets:
        #- 'zd1-ingress:8080'
        - 'zd2-ingress:8080'
        #- 'zd3-ingress:8080'
        #- 'zd4-ingress:8080'
        #- 'zd5-ingress:8080'
        #- 'zd6-ingress:8080'
        - 'zd7-ingress:8080'
  
  - job_name: zcash
    metrics_path: /metrics
    static_configs:
      - targets:
        - 'zcash-dev:9999'

  # federate metrics from the rocketpool monitoring stack
  - job_name: 'federate'
    scrape_interval: 30s

    #honor_labels: true
    metrics_path: '/federate'

    params:
      'match[]':
        - '{job="eth1"}'
        - '{job="eth2"}'
        - '{job="validator"}'
        - '{job="node"}'
        - '{job="prometheus"}'
        - '{job="rocketpool"}'
        - '{job="watchtower"}'
        #- '{__name__=~"job:.*"}'

    static_configs:
      - targets:
        - 'rocketpool-mainnet:9091'
        - 'rocketpool-signer:9091'

