#!/usr/sbin/nft -f
# Ansible-managed nftables configuration for Proxmox
# Generated from: group_vars/proxmox/firewall.yml
# Host: {{ inventory_hostname }}
# DO NOT EDIT MANUALLY

flush ruleset

# ============================================================================
# FILTER TABLE - IP sets and filtering rules
# ============================================================================
table inet filter {
  
  # Define IP sets
{% if nftables_ipsets is defined %}
{% for set_name, cidrs in nftables_ipsets.items() %}
  set {{ set_name }} {
    type ipv4_addr
    flags interval
    elements = { {{ cidrs | join(', ') }} }
  }
{% endfor %}
{% endif %}

  # Rate-limited logging helper chains
  chain input_log_drop {
    limit rate 10/minute burst 20 packets
    log prefix "NFT_INPUT_DROP " level notice
    drop
  }

  chain invalid_log_drop {
    limit rate 5/minute burst 10 packets
    log prefix "NFT_INVALID_DROP " level notice
    drop
  }

  chain forward_log_drop {
    limit rate 10/minute burst 20 packets
    log prefix "NFT_FORWARD_DROP " level notice
    drop
  }

  chain output_log_drop {
    limit rate 10/minute burst 20 packets
    log prefix "NFT_OUTPUT_DROP " level notice
    drop
  }

  # INPUT chain
  chain input {
    type filter hook input priority filter; policy {{ nftables_input_policy | default('drop') }};
    
    # Connection tracking
    ct state invalid jump invalid_log_drop
    ct state established,related accept
    
    # Custom input rules
{% if nftables_input_rules is defined %}
{% for rule_item in nftables_input_rules %}
    # {{ rule_item.comment }}
    {{ rule_item.rule }}
{% endfor %}
{% endif %}

    # Log and drop any remaining input traffic before policy drop.
    jump input_log_drop
  }

  # FORWARD chain
  chain forward {
    type filter hook forward priority filter; policy {{ nftables_forward_policy | default('accept') }};

    # Connection tracking
    ct state invalid jump invalid_log_drop
    ct state established,related accept

    # Custom forward rules
{% if nftables_forward_rules is defined %}
{% for rule_item in nftables_forward_rules %}
    # {{ rule_item.comment }}
    {{ rule_item.rule }}
{% endfor %}
{% endif %}

  # Use the forward_log_drop helper in explicit deny rules when logging is desired.

    # CRITICAL: MSS Clamping for SDN/VXLAN/WireGuard
    # This fixes the MTU 1358 vs 1500 issues automatically
    tcp flags syn tcp option maxseg size set rt mtu

    # Allow traffic from SDN to WAN (needed if policy is drop)
    #iifname "vnet+" oifname "{{ public_bridge }}" accept
    #ct state established,related accept
  }

  # OUTPUT chain
  chain output {
    type filter hook output priority filter; policy {{ nftables_output_policy | default('accept') }};

    # Custom output rules
{% if nftables_output_rules is defined %}
{% for rule_item in nftables_output_rules %}
    # {{ rule_item.comment }}
    {{ rule_item.rule }}
{% endfor %}
{% endif %}

    # Use the output_log_drop helper in explicit deny rules when logging is desired.
  }
}

# ============================================================================
# NAT TABLE - DNAT and SNAT rules
# ============================================================================
# FIX: Use 'inet' family to avoid conflict with legacy iptables/Proxmox rules
table inet nat {
  
  # PREROUTING chain (DNAT - port forwarding)
  chain prerouting {
    # Priority -100 corresponds to 'dstnat'
    type nat hook prerouting priority -100; policy accept;
    
{% if nftables_dnat_rules is defined and nftables_dnat_rules | length > 0 %}
    # DNAT rules (port forwarding to workloads)
{% for dnat in nftables_dnat_rules %}
    # {{ dnat.name }}
    iifname "{{ public_iface }}" {{ dnat.protocol }} dport {{ dnat.host_port }} dnat ip to {{ dnat.workload_ip }}:{{ dnat.workload_port }}
{% endfor %}
{% endif %}
  }

  # POSTROUTING chain (SNAT for outbound traffic)
  chain postrouting {
    # Priority 100 corresponds to 'srcnat'
    type nat hook postrouting priority 100; policy accept;
    
    # SNAT rules using existing variable names
{% if private_subnet is defined and public_iface is defined and public_ip is defined %}
    # SNAT traffic from private subnet guests
    ip saddr {{ private_subnet }} oifname "{{ public_iface }}" snat ip to {{ public_ip }}
{% endif %}

{% if admin_net is defined and public_iface is defined and public_ip is defined %}
    # SNAT traffic from private admin hosts
    ip saddr {{ admin_net }} oifname "{{ public_iface }}" snat ip to {{ public_ip }}
{% endif %}

{% if anycast_subnets is defined and public_iface is defined and public_ip is defined %}
    # SNAT traffic from SDN subnet guests
{% for anycast_subnet in anycast_subnets %}
    ip saddr {{ anycast_subnet }} oifname "{{ public_iface }}" snat ip to {{ public_ip }}
{% endfor %}
{% endif %}
  }
}